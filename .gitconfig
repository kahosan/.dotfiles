[user]
    name = kahosan
    email = 15116355657l@gmail.com
[core]
    editor = nvim
[init]
    defaultBranch = main
[merge]
    conflictstyle = zdiff3
[diff]
    algorithm = histogram
    tool = nvimdiff
[difftool]
    prompt = false
[difftool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[merge]
    tool = nvimdiff
[mergetool]
    prompt = false
[mergetool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\" \"$MERGED\" -c 'wincmd w' -c 'wincmd J'"
[log]
    date = iso
[alias]
    undo = reset --soft HEAD^
    cancel = reset --hard HEAD^
    onemore = commit -a --amend --no-edit

